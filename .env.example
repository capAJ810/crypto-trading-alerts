# Copy to .env for local runs. In GitHub Actions these live in repo Secrets.

# ── Email (Gmail) ────────────────────────────────────────────────────
GMAIL_USER=your_email@gmail.com
# App password from https://myaccount.google.com/apppasswords
# IMPORTANT: remove the spaces Google shows (store as 16 characters, no spaces)
GMAIL_APP_PASSWORD=abcdefghijklmnop
# Recipients, ';'-separated, each optionally limited to coins with ':'
#   a@x.com:BTC,ETH;b@y.com        -> a@x only BTC+ETH, b@y all coins
# Plain comma list also works (everyone gets everything).
ALERT_EMAILS=manoharabhijat@gmail.com

# ── Telegram ─────────────────────────────────────────────────────────
# Create a bot with @BotFather → it gives you this token
TELEGRAM_BOT_TOKEN=123456789:AAAA-your-bot-token
# Slash-separated list for multiple chats/groups, e.g. 111111/222222
TELEGRAM_CHAT_IDS=111111111
